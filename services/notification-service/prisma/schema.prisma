generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String   // workflow_invite | workflow_action | trial_expiring
  channel    String   @default("in_app") // in_app | telegram | email
  title      String
  message    String
  read       Boolean  @default(false)
  relatedId  String?  // workflowId or memberId for actions
  status     String   @default("pending") // pending | sent | failed
  error      String?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([userId, read])
  @@map("notifications")
}

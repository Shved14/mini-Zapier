generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // workflow_invite | trial_expiration | workflow_error
  channel   String   // telegram | email
  title     String
  message   String
  status    String   @default("pending") // pending | sent | failed
  error     String?
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@map("notifications")
}

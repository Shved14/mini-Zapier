# Trigger Service Configuration
PORT=3004
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/minizapier_triggers

# Redis
REDIS_URL=redis://localhost:6379

# Service URLs
EXECUTION_SERVICE_URL=http://localhost:3003

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_BASE_URL=http://localhost:3004/webhooks

# Logging
LOG_LEVEL=info

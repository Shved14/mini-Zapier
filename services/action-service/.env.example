# Action Service Configuration
PORT=3005
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/minizapier_actions

# Redis
REDIS_URL=redis://localhost:6379

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Database Connections
POSTGRES_URL=postgresql://user:password@localhost:5432/database
MYSQL_URL=mysql://user:password@localhost:3306/database
MONGODB_URL=mongodb://localhost:27017/database

# Logging
LOG_LEVEL=info

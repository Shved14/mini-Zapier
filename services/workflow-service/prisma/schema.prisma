generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id           String   @id @default(cuid())
  userId       String
  name         String
  workflowJson Json
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("workflows")
}

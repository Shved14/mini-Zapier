{
  "name": "mini-zapier-backend",
  "version": "1.0.0",
  "description": "Workflow automation backend similar to Zapier, built with Node.js, Express, TypeScript, Prisma, PostgreSQL, BullMQ, and Redis.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "workflow",
    "automation",
    "zapier",
    "nodejs",
    "express",
    "typescript",
    "prisma",
    "bullmq",
    "redis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "bullmq": "^4.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}

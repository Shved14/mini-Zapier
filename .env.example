NODE_ENV=development
PORT=4000

# PostgreSQL (used by Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_zapier?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth / JWT
JWT_SECRET=super_secret_jwt_key_change_me
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:4000/api/auth/github/callback

# Magic link
MAGIC_LINK_SECRET=super_secret_magic_key_change_me
MAGIC_LINK_BASE_URL=http://localhost:4000

# Telegram (опционально для telegram-steps)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_DEFAULT_CHAT_ID=your_default_chat_id_here

# SMTP (опционально для email-steps)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="Mini Zapier <user@example.com>"


